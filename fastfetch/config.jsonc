{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    //"type": "kitty",
    //"source": "/home/shorin/Pictures/picture.png",
    "width": 25,
    // "height":20,
    "color":{
      "1":"#4ddad9",
      "2":"#4ddad9"
    },
    "padding": {
      "top": 1, // Top padding
      "left": 2, // Left padding
      "right": 2 // Right padding
    },
  },
  "display": {
    "separator": " ", // Separator between keys and values
    "color": {
      //"keys": "#b0cccb", // Key color moduleеҗҚеӯ—зҡ„йўңиүІ
      "title": "#bec9c8", // Title color дё»жңәеҗҚзҡ„йўңиүІ
      "output": "#bec9c8"
    },
  },
  "modules": [
    "break",
    {
      "type": "os", //иҝҷжҳҜе“ӘдёӘmodule
      "key": "OS", //moduleеҗҚеӯ—зҡ„жҳҫзӨә
      // "keyColor": "#00ff00",      //moduleеҗҚеӯ—йўңиүІ
      // "format": "{name} {version}",    //е…·дҪ“еҶ…е®№
      "keyColor": "#4ddad9",
   
    },
    {
      "type": "kernel",
      "key": " в”ң пҢ…  KER ",
      "keyColor": "#4ddad9",

    },
    {
      "type": "packages",
      "key": " в”ң п’Ү  PAK ",
      "format": "{all}",
      "keyColor": "#4ddad9",
    },
    {
      "type": "command",
      "key": " в”ң пҲһ  AGE ",
      "text": "birth_install=$(stat -c %W / 2>/dev/null || stat -f %B /); current=$(date +%s); days_difference=$(( (current - birth_install) / 86400 )); echo $days_difference days",
      "keyColor": "#4ddad9",
    },
    {
      "type": "title",
      "key": " в”” пҠҪ  USR ",
      "keyColor": "#4ddad9",
    },
    "break",
    "break",
    {
      "type": "wm",
      "key": "WM",
      "keyColor": "#b2c8e8",
   },
    {
      "type": "de",
      "key": " в”ң уұҲ№  DES ",
      "keyColor": "#b2c8e8",
     //"outputColor": "#b2c8e8"
    },
    {
      "type": "shell",
      "key": " в”ң п„   SHE ",
      "keyColor": "#b2c8e8",
      //"outputColor": "#b2c8e8"
    },
    {
      "type": "terminal",
      "key": " в”ң п’ү  TER ",
      "keyColor": "#b2c8e8",
      //"outputColor": "#b2c8e8"
    },
    {
      "type": "terminalfont",
      "key": " в”” пҖұ  TFO ",
      "keyColor": "#b2c8e8",
      //"outputColor": "#b2c8e8"
    },
    "break",
    "break",
    {
      "type": "host",
      "key": "PC ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "cpu",
      "key": " в”ң п’ј  CPU ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "memory",
      "key": " в”ң оҝ…  MEM ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "swap",
      "key": " в”ң оҝ…  SWP ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "gpu",
      "key": " в”ң у°ў®  GPU ",
      "format": "{1} {2}",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "display",
      "key": " в”ң п„Ҳ  MON ",
      "format": "{name} {width}x{height}@{refresh-rate} ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    {
      "type": "disk",
      "key": " в”” у°ӢҠ  DIS ",
      "keyColor": "#cce8e7",
      //"outputColor": "#b0cccb"
    },
    "break",
    "break",
    "colors"
  ]
}
